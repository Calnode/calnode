# Binaries (anchored to repo root so cmd/calnode/ source is not ignored)
/calnode
/calnode.exe

# Local Claude Code tooling: per-developer dev-server config (launch.json) and the
# machine-specific permission allowlist (settings.local.json) — never shared.
/.claude/

# Internal/strategy docs (PRD, roadmap, planning notes) — never published.
# /docs/ itself is tracked normally; it's the public-facing reference set.
/internal-docs/
*.exe
*.exe~

# Build output
dist/

# graphify skill output — knowledge-graph dumps; kept local for now (revisit later)
/graphify-out/

# Data (local dev DB)
data/
data-demo/
*.db
*.db-shm
*.db-wal

# Environment — allow .env.example as a committed template
.env
.env.*
!.env.example

# Go
vendor/
*.test
coverage.out
*.coverprofile
*.prof
__debug_bin

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# sqlc generated — committed, but excluded from accidental manual edits
# (remove this line if you want to exclude generated files from git)
# internal/db/sqlc/

# Node (admin UI)
node_modules/
.svelte-kit/
build/
pnpm-debug.log*

# Vitest browser-mode artifacts (failure screenshots / attachments)
__screenshots__/
.vitest-attachments/
